<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pengshz.dingtalk-random-scheduler</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/caffeinate</string>
        <string>-i</string>
        <string>/usr/bin/env</string>
        <string>python3</string>
        <string>/ABSOLUTE/PATH/TO/DingTalkHybridDesktop/backend/dingtalk_random_scheduler.py</string>
        <string>run</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/DingTalkHybridDesktop/backend</string>

    <key>StandardOutPath</key>
    <string>/ABSOLUTE/PATH/TO/DingTalkHybridDesktop/backend/logs/dingtalk-random-scheduler.log</string>

    <key>StandardErrorPath</key>
    <string>/ABSOLUTE/PATH/TO/DingTalkHybridDesktop/backend/logs/dingtalk-random-scheduler.err.log</string>
</dict>
</plist>
